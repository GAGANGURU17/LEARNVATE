                Subscribe to our newsletter for the latest features and learning tips.
              </p>
              <form className="mt-4 flex flex-col sm:flex-row gap-3">
                <div className="relative flex-1">
                  <Mail className="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-slate-400" />
                  <input
                    type="email"
                    placeholder="Enter your email"
                    className="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-saffron-500 focus:border-transparent text-sm transition-shadow"
                    required
                  />
                </div>
                <button
                  type="submit"
                  className="btn-primary py-3 px-6 whitespace-nowrap rounded-xl shadow-md"
                >
                  Subscribe
                </button>
              </form>
            </div>
          </div>

          <div className="mt-16 pt-8 border-t border-slate-200 flex flex-col md:flex-row items-center justify-between gap-6">
            <p className="text-sm text-slate-400 flex items-center gap-2">
              <span>© {new Date().getFullYear()} LEARNVATE. All rights reserved.</span>
            </p>
            
            <div className="flex flex-wrap items-center justify-center gap-6">
              {[
                { label: 'Terms', href: '/terms' },
                { label: 'Privacy', href: '/privacy' },
                { label: 'Cookies', href: '/cookies' },
              ].map((item) => (
                <Link key={item.label} href={item.href} className="text-slate-400 text-sm hover:text-saffron-600 transition-colors">
                  {item.label}
                </Link>
              ))}
              
              <div className="flex items-center gap-2 text-sm text-slate-500 bg-slate-50 px-3 py-1.5 rounded-full border border-slate-200 ml-0 sm:ml-4 mt-2 sm:mt-0">
                <Globe className="h-4 w-4 text-slate-400" />
                <span>English (US)</span>
              </div>
            </div>
          </div>
        </div>
      </footer>
    </div>
  );
}
